<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Debug configuration: Allow localhost cleartext for emulator -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <dns-over-https>
            <server addr="https://dns.google/dns-query" />
        </dns-over-https>
    </base-config>

    <!-- Allow cleartext to localhost for local development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>

    <!-- Certificate pinning for API (same pins as release) -->
    <domain-config>
        <domain includeSubdomains="true">dakkho-api.pages.dev</domain>
        <pin-set>
            <pin digest="SHA-256">PLACEHOLDER_PIN_1_REPLACE_WITH_REAL_SHA256=</pin>
            <pin digest="SHA-256">PLACEHOLDER_PIN_2_REPLACE_WITH_REAL_SHA256=</pin>
            <pin digest="SHA-256">PLACEHOLDER_BACKUP_PIN_REPLACE_WITH_REAL_SHA256=</pin>
        </pin-set>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
