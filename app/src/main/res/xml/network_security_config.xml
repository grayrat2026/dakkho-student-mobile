<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Release configuration: No cleartext traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Certificate pinning for API (pins will be added when real SHA-256 hashes are available) -->
    <domain-config>
        <domain includeSubdomains="true">dakkho-api.pages.dev</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
